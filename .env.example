# nginx 뒤에 있으므로 호스트에 직접 노출 불필요. 직접 접근이 필요한 경우 주석 해제
# API_PORT=8000
# FRONTEND_PORT=8501
NGINX_PORT=5001

PYTHON_VERSION=3.12
TORCH_INDEX=https://download.pytorch.org/whl/cu128  # cu128 (GPU), cpu (CPU)
TORCH_VERSION=2.10.*

DEVICE=cuda  # cpu, cuda
GPU_COUNT=all  # 0, 1, 2, 3, ..., all

LOG_LEVEL=info
